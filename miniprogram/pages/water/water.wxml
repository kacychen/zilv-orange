<view class="page-wrap">
  <!-- 顶部波浪组件 -->
  <water-wave
    amount="{{totalAmount}}"
    goal="{{waterGoal}}"
    percent="{{percent}}"
  ></water-wave>

  <!-- 统计小卡 -->
  <view class="stats-row">
    <view class="stat-card">
      <text class="stat-val">{{cupCount}}</text>
      <text class="stat-label">今日杯数</text>
    </view>
    <view class="stat-card">
      <text class="stat-val">{{streakDays}}</text>
      <text class="stat-label">连续达标天</text>
    </view>
    <view class="stat-card">
      <text class="stat-val">{{yesterdayAmount}}</text>
      <text class="stat-label">昨日 ml</text>
    </view>
  </view>

  <!-- 今日记录 -->
  <view class="section-title" wx:if="{{records.length > 0}}">今日记录</view>
  <view class="timeline" wx:if="{{records.length > 0}}">
    <view
      class="tl-item-wrap"
      wx:for="{{records}}"
      wx:key="_id"
      data-index="{{index}}"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    >
      <view class="tl-slide-inner" style="transform: translateX({{item._slideX || 0}}rpx);">
        <view class="tl-item">
          <view class="tl-dot">
            <image wx:if="{{item.type === 'water'}}" class="tl-dot-img" src="/images/icon-water.svg" mode="aspectFit"/>
            <text wx:else class="tl-dot-icon">{{item.icon}}</text>
          </view>
          <view class="tl-info">
            <text class="tl-name">{{item.type_name}}</text>
            <text class="tl-time">{{item.timeStr}}</text>
          </view>
          <text class="tl-amount">{{item.amount}}ml</text>
        </view>
        <view class="tl-delete-btn" bindtap="onDeleteRecord" data-index="{{index}}">
          <text class="tl-delete-text">删除</text>
        </view>
      </view>
    </view>
  </view>
  <view class="timeline-empty" wx:else>
    <text class="empty-text">今天还没有记录，喝点水吧 💧</text>
  </view>

  <!-- 底部占位，防止被按钮遮住 -->
  <view class="bottom-placeholder"></view>
</view>

<!-- 固定底部喝水按钮 -->
<view class="add-btn-wrap">
  <view class="add-btn" bindtap="onAddWaterTap">
    <text class="add-btn-text">＋ 喝水</text>
  </view>
</view>

<!-- 第一步：选择饮品类型 -->
<view class="sheet-mask" wx:if="{{showDrinkPicker}}" bindtap="onDrinkPickerClose"></view>
<view class="bottom-sheet {{showDrinkPicker ? 'bottom-sheet-show' : ''}}">
  <view class="sheet-header">
    <text class="sheet-title">选择饮品</text>
    <view class="sheet-close" bindtap="onDrinkPickerClose">✕</view>
  </view>
  <view class="drink-grid">
    <view
      class="drink-item"
      wx:for="{{drinkTypes}}"
      wx:key="type"
      data-drink="{{item}}"
      bindtap="onDrinkTap"
    >
      <view class="drink-icon-wrap">
        <image wx:if="{{item.type === 'water'}}" class="drink-img" src="/images/icon-water.svg" mode="aspectFit"/>
        <text wx:else class="drink-icon">{{item.icon}}</text>
      </view>
      <text class="drink-name">{{item.type_name}}</text>
    </view>
  </view>
</view>

<!-- 第二步：选择容量 -->
<view class="sheet-mask" wx:if="{{showAmountPicker}}" bindtap="onPickerMaskTap"></view>
<view class="bottom-sheet {{showAmountPicker ? 'bottom-sheet-show' : ''}}">
  <view class="sheet-header">
    <view class="sheet-back" bindtap="onPickerBack">←</view>
    <text class="sheet-title">选择容量</text>
    <view class="sheet-close" bindtap="onPickerClose">✕</view>
  </view>
  <view class="picker-drink-label">
    <image wx:if="{{selectedDrink.type === 'water'}}" class="drink-img" src="/images/icon-water.svg" mode="aspectFit" style="width:40rpx;height:40rpx;"/>
    <text wx:else class="picker-drink-icon">{{selectedDrink.icon}}</text>
    <text class="picker-drink-name">{{selectedDrink.type_name}}</text>
  </view>
  <view class="amount-grid">
    <view
      class="amount-item {{item === selectedAmount && !useCustom ? 'amount-item-active' : ''}}"
      wx:for="{{amountPresets}}"
      wx:key="*this"
      data-amount="{{item}}"
      bindtap="onAmountTap"
    >
      <text>{{item}}ml</text>
    </view>
  </view>
  <view class="custom-amount-row" bindtap="onCustomToggle">
    <view class="custom-radio {{useCustom ? 'custom-radio-active' : ''}}"></view>
    <text class="custom-label">自定义</text>
    <input
      class="custom-amount-input"
      type="number"
      placeholder="请输入..."
      placeholder-style="color:#ccc;"
      value="{{customAmount}}"
      bindinput="onCustomInput"
      disabled="{{!useCustom}}"
    />
    <text class="custom-unit">ml</text>
  </view>
  <view class="picker-confirm-btn" bindtap="onAmountConfirm">
    <text class="picker-confirm-text">保存</text>
  </view>
</view>

<!-- 首次使用目标设置弹窗 -->
<view class="modal-mask" wx:if="{{showGoalModal}}" bindtap="onMaskTap">
  <view class="modal-box" catchtap="">
    <text class="modal-title">设置每日饮水目标</text>
    <text class="modal-desc">输入体重，我们帮你推算推荐量</text>
    <view class="modal-row">
      <text class="modal-label">体重（kg）</text>
      <input
        class="modal-input"
        type="number"
        placeholder="如：65"
        value="{{weightInput}}"
        bindinput="onWeightInput"
      />
    </view>
    <view class="modal-row">
      <text class="modal-label">每日目标（ml）</text>
      <input
        class="modal-input"
        type="number"
        placeholder="推荐值将自动填入"
        value="{{goalInput}}"
        bindinput="onGoalInput"
      />
    </view>
    <view class="modal-btns">
      <view class="modal-btn modal-btn-cancel" bindtap="onGoalCancel">
        <text>使用默认 2000ml</text>
      </view>
      <view class="modal-btn modal-btn-confirm" bindtap="onGoalConfirm">
        <text>确认</text>
      </view>
    </view>
  </view>
</view>
