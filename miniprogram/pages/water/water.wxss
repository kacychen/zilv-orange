page {
  background: #f0f4f8;
}

.page-wrap {
  min-height: 100vh;
  background: #f0f4f8;
}

/* 固定底部喝水按钮 */
.add-btn-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx 48rpx;
  background: linear-gradient(to top, #f0f4f8 70%, transparent);
  z-index: 10;
}

.add-btn {
  background: linear-gradient(135deg, #3b9ded, #1565c0);
  border-radius: 50rpx;
  padding: 28rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(59,157,237,0.45);
}

.add-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

/* 底部占位，防止内容被固定按钮遮住 */
.bottom-placeholder {
  height: 160rpx;
}

/* 最近一条记录预览卡 */
.last-record {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin: 24rpx 24rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.last-record-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.last-record-icon {
  font-size: 40rpx;
}

.last-record-name {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.last-record-time {
  display: block;
  font-size: 22rpx;
  color: #aaa;
  margin-top: 4rpx;
}

.last-record-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #1565c0;
}

/* 底部弹层蒙层 */
.sheet-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

/* 底部弹层 */
.bottom-sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 32rpx 60rpx;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.bottom-sheet-show {
  transform: translateY(0);
}

/* 弹层头部 */
.sheet-header {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 24rpx;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.sheet-back {
  position: absolute;
  left: 0;
  font-size: 40rpx;
  color: #555;
  padding: 8rpx 16rpx 8rpx 0;
}

.sheet-close {
  position: absolute;
  right: 0;
  font-size: 32rpx;
  color: #999;
  padding: 8rpx 0 8rpx 16rpx;
}

/* 统计小卡 */
.stats-row {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 24rpx 0;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.stat-val {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1565c0;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 区块标题 */
.section-title {
  font-size: 26rpx;
  color: #999;
  padding: 28rpx 24rpx 12rpx;
  letter-spacing: 1rpx;
}

.drink-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}

.drink-img {
  width: 56rpx;
  height: 56rpx;
  display: block;
  transform: translateY(-8rpx);
}

.drink-icon {
  font-size: 60rpx;
  line-height: 1;
  display: block;
}

/* 饮品网格 */
.drink-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0;
}

.drink-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0 20rpx;
  box-sizing: border-box;
  gap: 12rpx;
}

.drink-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.drink-name {
  font-size: 26rpx;
  color: #333;
}

/* 底部容量弹层 */
.picker-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 200;
}

.picker-sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 32rpx 60rpx;
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.picker-sheet-show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.picker-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx 16rpx;
}

.picker-drink-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.picker-drink-icon {
  font-size: 40rpx;
}

.picker-drink-name {
  font-size: 28rpx;
  color: #555;
}

.amount-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.amount-item {
  padding: 18rpx 28rpx;
  border: 2rpx solid #ddd;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #333;
}

.amount-item-active {
  background: #1565c0;
  border-color: #1565c0;
  color: #fff;
}

.custom-amount-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
  margin-bottom: 28rpx;
}

.custom-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
  flex-shrink: 0;
}

.custom-radio-active {
  border-color: #1565c0;
  background: #1565c0;
}

.custom-label {
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.custom-amount-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #ddd;
  padding-bottom: 4rpx;
}

.custom-unit {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

.picker-confirm-btn {
  background: linear-gradient(135deg, #3b9ded, #1565c0);
  border-radius: 50rpx;
  padding: 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(59,157,237,0.4);
}

.picker-confirm-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

/* 时间线 */
.timeline {
  padding: 0 24rpx;
  margin-top: 8rpx;
}

.tl-item-wrap {
  overflow: hidden;
  margin-bottom: 12rpx;
}

.tl-slide-inner {
  display: flex;
  flex-direction: row;
  width: calc(100% + 160rpx);
  will-change: transform;
}

.tl-item {
  flex-shrink: 0;
  width: calc(100% - 160rpx);
  box-sizing: border-box;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.tl-dot {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #EFF6FF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tl-dot-img {
  width: 40rpx;
  height: 40rpx;
}

.tl-dot-icon {
  font-size: 36rpx;
}

.tl-info {
  flex: 1;
}

.tl-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.tl-time {
  display: block;
  font-size: 22rpx;
  color: #aaa;
  margin-top: 4rpx;
}

.tl-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #1565c0;
  flex-shrink: 0;
  white-space: nowrap;
}

.tl-delete-btn {
  flex-shrink: 0;
  width: 160rpx;
  background: #FF4444;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 20rpx 20rpx 0;
  align-self: stretch;
}

.tl-delete-text {
  color: #fff;
  font-size: 28rpx;
}

/* 空状态 */
.timeline-empty {
  padding: 60rpx 24rpx;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #bbb;
}

/* 目标设置弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-box {
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  width: 600rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
}

.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 12rpx;
}

.modal-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-row {
  margin-bottom: 28rpx;
}

.modal-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.modal-input {
  width: 100%;
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.modal-btn {
  flex: 1;
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
}

.modal-btn-cancel {
  background: #f0f0f0;
  color: #666;
}

.modal-btn-confirm {
  background: linear-gradient(135deg, #3b9ded, #1565c0);
  color: #fff;
  font-weight: 600;
}
