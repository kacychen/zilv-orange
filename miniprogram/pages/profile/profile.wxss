/* 用户头部 */
.profile-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #FFF3E0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-emoji {
  font-size: 50rpx;
}

.profile-info {
  flex: 1;
}

.profile-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.tag-row {
  margin-top: 10rpx;
  display: flex;
}

.edit-btn {
  padding: 12rpx;
}

.edit-icon {
  font-size: 36rpx;
}

/* 统计 */
.stats-row {
  display: flex;
  align-items: center;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #FF7A00;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #F0F0F0;
}

/* 信息列表 */
.info-list {
  margin-top: 10rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

/* 成就徽章 */
.achievements-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 10rpx;
}

.achievement-item {
  width: calc(33.33% - 14rpx);
  background: #FFF3E0;
  border-radius: 16rpx;
  padding: 20rpx 10rpx;
  text-align: center;
}

.achievement-icon {
  font-size: 44rpx;
  display: block;
  margin-bottom: 8rpx;
}

.achievement-name {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #FF7A00;
}

.achievement-desc {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.empty-achievements {
  padding: 40rpx 0;
  text-align: center;
}

/* 编辑弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

.edit-modal {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  bottom: 0;
  z-index: 101;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 85vh;
  overflow-y: auto;
  padding-bottom: 40rpx;
}

.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-item.half {
  flex: 1;
}

.option-group {
  display: flex;
  gap: 12rpx;
}

.option-btn {
  flex: 1;
  height: 72rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.option-btn.selected {
  background: #FFF3E0;
  color: #FF7A00;
  border-color: #FF7A00;
  font-weight: 600;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-back {
  flex: 0 0 160rpx;
  height: 88rpx;
  background: #F0F0F0;
  color: #666;
  border: none;
  border-radius: 48rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-back::after {
  border: none;
}

.flex1 {
  flex: 1;
}

/* ── 会员状态卡片 ── */
.member-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #FFF3E0, #FFF8F3);
  border: 1rpx solid #FFD9A8;
}

.member-card-inactive {
  background: #FAFAFA;
  border: 1rpx solid #F0F0F0;
}

.member-card-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.member-card-icon {
  font-size: 48rpx;
}

.member-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.member-card-expire {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.member-card-tag {
  background: linear-gradient(135deg, #FF7A00, #FFB347);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

.member-activate-btn {
  background: linear-gradient(135deg, #FF7A00, #FFB347);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
}
