<view class="container">
  <view class="header">
    <text class="title">🍊 欢迎使用自律橙子</text>
    <text class="subtitle">填写基本信息，为你定制专属目标</text>
  </view>

  <!-- 步骤指示 -->
  <view class="steps">
    <view class="step {{step >= 1 ? 'active' : ''}}">1</view>
    <view class="step-line"></view>
    <view class="step {{step >= 2 ? 'active' : ''}}">2</view>
    <view class="step-line"></view>
    <view class="step {{step >= 3 ? 'active' : ''}}">3</view>
  </view>

  <!-- 步骤一：基本信息 -->
  <view wx:if="{{step === 1}}" class="form-card card">
    <text class="form-title">基本信息</text>

    <view class="form-item">
      <text class="form-label">昵称</text>
      <input class="form-input" placeholder="请输入昵称" value="{{form.nickname}}" bindinput="onInput" data-field="nickname" />
    </view>

    <view class="form-item">
      <text class="form-label">性别</text>
      <view class="radio-group">
        <view class="radio-item {{form.gender === 1 ? 'selected' : ''}}" bindtap="setGender" data-value="1">男</view>
        <view class="radio-item {{form.gender === 2 ? 'selected' : ''}}" bindtap="setGender" data-value="2">女</view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">出生年月</text>
      <picker mode="date" value="{{form.birthday}}" start="1950-01-01" end="2010-12-31" bindchange="onBirthday">
        <view class="picker-value {{form.birthday ? '' : 'placeholder'}}">
          {{form.birthday || '请选择出生年月'}}
        </view>
      </picker>
    </view>

    <button class="btn-primary next-btn" bindtap="nextStep">下一步</button>
  </view>

  <!-- 步骤二：身体数据 -->
  <view wx:if="{{step === 2}}" class="form-card card">
    <text class="form-title">身体数据</text>

    <view class="form-item">
      <text class="form-label">身高 (cm)</text>
      <input class="form-input" type="digit" placeholder="例如 170" value="{{form.height}}" bindinput="onInput" data-field="height" />
    </view>

    <view class="form-item">
      <text class="form-label">当前体重 (kg)</text>
      <input class="form-input" type="digit" placeholder="例如 65" value="{{form.weight}}" bindinput="onInput" data-field="weight" />
    </view>

    <view class="form-item">
      <text class="form-label">目标体重 (kg)</text>
      <input class="form-input" type="digit" placeholder="例如 60" value="{{form.target_weight}}" bindinput="onInput" data-field="target_weight" />
    </view>

    <view class="btn-row">
      <button class="btn-back" bindtap="prevStep">上一步</button>
      <button class="btn-primary next-btn flex1" bindtap="nextStep">下一步</button>
    </view>
  </view>

  <!-- 步骤三：目标设置 -->
  <view wx:if="{{step === 3}}" class="form-card card">
    <text class="form-title">目标设置</text>

    <view class="form-item">
      <text class="form-label">健康目标</text>
      <view class="option-group">
        <view class="option-item {{form.goal === 'lose_weight' ? 'selected' : ''}}" bindtap="setGoal" data-value="lose_weight">
          <text class="option-icon">🎯</text>
          <text class="option-text">减脂</text>
        </view>
        <view class="option-item {{form.goal === 'maintain' ? 'selected' : ''}}" bindtap="setGoal" data-value="maintain">
          <text class="option-icon">⚖️</text>
          <text class="option-text">维持</text>
        </view>
        <view class="option-item {{form.goal === 'gain_muscle' ? 'selected' : ''}}" bindtap="setGoal" data-value="gain_muscle">
          <text class="option-icon">💪</text>
          <text class="option-text">增肌</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">日常活动量</text>
      <view class="activity-list">
        <view class="activity-item {{form.activity_level === 'sedentary' ? 'selected' : ''}}" bindtap="setActivity" data-value="sedentary">
          <text class="activity-title">久坐</text>
          <text class="activity-desc">基本不运动，办公室工作</text>
        </view>
        <view class="activity-item {{form.activity_level === 'light' ? 'selected' : ''}}" bindtap="setActivity" data-value="light">
          <text class="activity-title">轻度活动</text>
          <text class="activity-desc">每周 1-3 次轻度锻炼</text>
        </view>
        <view class="activity-item {{form.activity_level === 'moderate' ? 'selected' : ''}}" bindtap="setActivity" data-value="moderate">
          <text class="activity-title">中度活动</text>
          <text class="activity-desc">每周 3-5 次中等强度锻炼</text>
        </view>
        <view class="activity-item {{form.activity_level === 'active' ? 'selected' : ''}}" bindtap="setActivity" data-value="active">
          <text class="activity-title">高度活动</text>
          <text class="activity-desc">每天高强度锻炼或体力劳动</text>
        </view>
      </view>
    </view>

    <!-- 预估每日热量 -->
    <view class="calorie-preview" wx:if="{{estimatedCalorie > 0}}">
      <text class="preview-label">预计每日热量目标</text>
      <text class="preview-value text-number">{{estimatedCalorie}} kcal</text>
    </view>

    <view class="btn-row">
      <button class="btn-back" bindtap="prevStep">上一步</button>
      <button class="btn-primary next-btn flex1" bindtap="submit" loading="{{submitting}}">开始使用 🍊</button>
    </view>
  </view>
</view>
