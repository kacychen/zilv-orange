<view class="nutrient-item">
  <view class="nutrient-header">
    <text class="nutrient-name">{{name}}</text>
    <text class="nutrient-value text-number">{{current}}g / {{target}}g</text>
  </view>
  <view class="bar-bg">
    <view class="bar-fill" style="transform: scaleX({{percent / 100}}); background: {{color}};"></view>
  </view>
</view>
