.ring-container {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto;
}

.ring-canvas {
  width: 400rpx;
  height: 400rpx;
}

.ring-center {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ring-value {
  font-size: 64rpx;
  color: #FF7A00;
  font-weight: 700;
}

.ring-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}
